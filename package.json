{
  "name": "spherical-delaunay",
  "version": "0.1.0",
  "description": "Spherical Delaunay triangulation via 3D convex hull, with O(sqrt(N)) nearest-neighbor queries",
  "license": "ISC",
  "author": "Chris Steinbach",
  "homepage": "https://github.com/ChrisSteinbach/spherical-delaunay#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChrisSteinbach/spherical-delaunay.git"
  },
  "bugs": {
    "url": "https://github.com/ChrisSteinbach/spherical-delaunay/issues"
  },
  "keywords": [
    "delaunay",
    "spherical",
    "triangulation",
    "convex-hull",
    "nearest-neighbor",
    "great-circle",
    "geospatial",
    "voronoi",
    "computational-geometry",
    "sphere"
  ],
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "!src/**/*.test.ts"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky && npm run build",
    "prepublishOnly": "npm run typecheck && npm run lint && npm run format && npm test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.0"
  }
}
